---
import background from "../assets/background.svg";
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
	<header id="site-header">
		<div class="brand-block">
			<p class="site-title">Pickle</p>
			<p class="business-brand">The Wix Wiz</p>
		</div>
		<a class="cta-button" href="https://www.thewixwiz.com">Schedule Now</a>
	</header>
	<main>
		<section id="hero">
			<h1>Pickle</h1>
			<p class="subtitle">Eitan Waxman - Velo Certified Developer</p>
			<p class="business-brand">The Wix Wiz</p>
			<a class="cta-button hero-cta" href="https://www.thewixwiz.com">Schedule Now</a>
		</section>
	</main>
	<footer id="site-footer">
		<p>Eitan Waxman</p>
		<p>Velo Certified Developer</p>
		<p><a href="mailto:eitan@thewixwiz.com">eitan@thewixwiz.com</a></p>
		<p>
			<a href="https://www.thewixwiz.com" target="_blank" rel="noopener noreferrer"
				>https://www.thewixwiz.com</a
			>
		</p>
	</footer>
</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}

	#container {
		font-family:
			Inter, Roboto, "Helvetica Neue", "Arial Nova", "Nimbus Sans", Arial, sans-serif;
		height: 100%;
		display: flex;
		flex-direction: column;
		color: #1f2430;
	}

	#site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 20px 24px;
	}

	.site-title {
		font-weight: 700;
		font-size: 1.05rem;
		margin: 0;
	}

	.business-brand {
		margin: 0.25rem 0 0;
		font-size: 0.92rem;
		opacity: 0.8;
	}

	.cta-button {
		display: inline-block;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		background: #1f2430;
		color: #fff;
		font-weight: 600;
		text-decoration: none;
	}

	.hero-cta {
		margin-top: 1rem;
		width: fit-content;
	}

	main {
		flex: 1;
		display: flex;
		justify-content: center;
		padding: 0 24px;
	}

	#hero {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 24px 16px;
		max-width: 720px;
		width: 100%;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		margin: 0;
	}

	.subtitle {
		font-size: clamp(1.1rem, 2.1vw, 1.4rem);
		margin: 0.6rem 0 0;
	}

	#site-footer {
		padding: 20px 24px 28px;
		border-top: 1px solid rgba(31, 36, 48, 0.15);
	}

	#site-footer p {
		margin: 0.2rem 0;
	}

	#site-footer a {
		color: inherit;
	}

	@media (max-width: 700px) {
		#site-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.9rem;
		}
	}
</style>
