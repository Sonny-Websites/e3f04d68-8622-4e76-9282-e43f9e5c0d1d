---
import background from "../assets/background.svg";
import pickleHero from "../assets/pickle-hero.png";
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
	<header id="site-header">
		<div class="brand-block">
			<p class="site-title">Pickle</p>
			<p class="business-brand">The Wix Wiz</p>
		</div>
		<a class="cta-button" href="https://www.thewixwiz.com">Schedule Now</a>
	</header>
	<main>
		<section id="hero">
			<div class="hero-copy">
				<h1>Pickle</h1>
				<p class="subtitle">Eitan Waxman - Velo Certified Developer</p>
				<p class="business-brand">The Wix Wiz</p>
				<a class="cta-button hero-cta" href="https://www.thewixwiz.com">Schedule Now</a>
			</div>
			<figure class="hero-art">
				<img src={pickleHero.src} alt="Pickle illustration" loading="eager" />
			</figure>
		</section>
	</main>
	<footer id="site-footer">
		<p>Eitan Waxman</p>
		<p>Velo Certified Developer</p>
		<p><a href="mailto:eitan@thewixwiz.com">eitan@thewixwiz.com</a></p>
		<p>
			<a href="https://www.thewixwiz.com" target="_blank" rel="noopener noreferrer"
				>https://www.thewixwiz.com</a
			>
		</p>
	</footer>
</div>

<style>
	:root {
		--text: #173727;
		--text-muted: #2e4f3d;
		--primary: #236b43;
		--primary-hover: #1b5434;
		--surface-soft: #e8f6ec;
	}

	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}

	#container {
		font-family:
			Inter, Roboto, "Helvetica Neue", "Arial Nova", "Nimbus Sans", Arial, sans-serif;
		height: 100%;
		display: flex;
		flex-direction: column;
		color: var(--text);
	}

	#site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 20px 24px;
	}

	.site-title {
		font-weight: 700;
		font-size: 1.05rem;
		margin: 0;
	}

	.business-brand {
		margin: 0.25rem 0 0;
		font-size: 0.92rem;
		color: var(--text-muted);
	}

	.cta-button {
		display: inline-block;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		background: var(--primary);
		color: #fff;
		font-weight: 600;
		text-decoration: none;
		transition: background-color 0.2s ease;
	}

	.cta-button:hover,
	.cta-button:focus-visible {
		background: var(--primary-hover);
	}

	.hero-cta {
		margin-top: 1rem;
		width: fit-content;
	}

	main {
		flex: 1;
		display: flex;
		justify-content: center;
		padding: 0 24px;
	}

	#hero {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(200px, 380px);
		gap: clamp(1rem, 4vw, 3rem);
		align-items: center;
		padding: 28px 18px;
		max-width: 980px;
		width: 100%;
		background: var(--surface-soft);
		border: 1px solid rgba(35, 107, 67, 0.24);
		border-radius: 1.25rem;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		margin: 0;
	}

	.subtitle {
		font-size: clamp(1.1rem, 2.1vw, 1.4rem);
		margin: 0.6rem 0 0;
	}

	.hero-art {
		margin: 0;
		display: flex;
		justify-content: center;
	}

	.hero-art img {
		display: block;
		width: min(100%, 340px);
		height: auto;
	}

	#site-footer {
		padding: 20px 24px 28px;
		border-top: 1px solid rgba(35, 107, 67, 0.28);
	}

	#site-footer p {
		margin: 0.2rem 0;
	}

	#site-footer a {
		color: var(--primary-hover);
	}

	#site-footer a:hover,
	#site-footer a:focus-visible {
		color: var(--primary);
	}

	@media (max-width: 700px) {
		#site-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.9rem;
		}

		#hero {
			grid-template-columns: 1fr;
			padding: 20px 16px;
		}

		.hero-art img {
			width: min(75vw, 290px);
		}
	}
</style>
